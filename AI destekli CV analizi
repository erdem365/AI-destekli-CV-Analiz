def extract_text_from_pdf(uploaded_file):
    """PDF'den metin çıkarır."""
    try:
        reader = PdfReader(uploaded_file)
        text = ""
        for page in reader.pages:
            extracted = page.extract_text()
            if extracted:
                text += extracted + "\n"
        return text.strip()
    except Exception as e:
        st.error(f"PDF okunurken hata oluştu: {e}")
        return ""

def analyze_cv(text):
    """CV metnini analiz eder: bölümler, skor, yetenekler."""
    if not text:
        return None, None, None, None

    text_lower = text.lower()
    words = text.split()
    word_count = len(words)

    # 1. Bölüm tespiti (Regex ile)
    sections = {
        "summary": bool(re.search(r'\b(özet|profil|hakkımda|summary|profile)\b', text_lower)),
        "education": bool(re.search(r'\b(eğitim|okul|üniversite|fakülte|education|university|college)\b', text_lower)),
        "experience": bool(re.search(r'\b(deneyim|iş tecrübesi|çalıştığı|experience|work|employment)\b', text_lower)),
        "skills": bool(re.search(r'\b(yetenek|beceri|skills|competencies|teknoloji|programlama)\b', text_lower)),
        "projects": bool(re.search(r'\b(proje|geliştirdi|tasarladı|project|development)\b', text_lower)),
        "certifications": bool(re.search(r'\b(sertifika|certification|belge|course)\b', text_lower)),
        "contact": bool(re.search(r'[\w\.-]+@[\w\.-]+\.\w+', text))  # email kontrolü
    }

    missing_sections = [sec for sec, val in sections.items() if not val]

    # 2. ATS Skoru Hesaplama (0-100)
    score = 0
    # İletişim (Email + Telefon varsa)
    if sections["contact"]:
        score += 15
    if re.search(r'(\d{10,15}|\+\d{1,4}\s?\d{10,15})', text):  # telefon
        score += 5  # toplam 20 (email+telefon)
    else:
        score += 10  # sadece email varsa

    if sections["summary"]: score += 10
    if sections["education"]: score += 15
    if sections["experience"]: score += 15
    if sections["skills"]: score += 20
    if sections["projects"]: score += 5
    if sections["certifications"]: score += 5

    # Kelime uzunluğu (ATS için ideal 300-800 kelime)
    if 300 <= word_count <= 800:
        score += 10
    elif 200 <= word_count < 300 or 800 < word_count <= 1200:
        score += 5
    else:
        score += 0

    # Anahtar kelime zenginliği (sektörel terimler)
    keyword_pattern = r'\b(başarı|yönetti|geliştirdi|tasarladı|analiz|rapor|ekip|proje|strateji|çözüm|leadership|managed|developed|analyzed|team|project|solution)\b'
    keywords = re.findall(keyword_pattern, text_lower)
    keyword_score = min(len(keywords) * 2, 10)  # max 10 puan
    score += keyword_score

    # Maksimum 100'ü geçmesin
    score = min(score, 100)

    # 3. Yetenek Analizi
    found_skills = {}
    for category, skills in SKILLS_DB.items():
        matched = []
        for skill in skills:
            if re.search(rf'\b{re.escape(skill)}\b', text_lower):
                matched.append(skill.title())
        if matched:
            found_skills[category] = matched

    # 4. Özet istatistikler
    stats = {
        "word_count": word_count,
        "has_contact": sections["contact"],
        "has_summary": sections["summary"],
        "has_education": sections["education"],
        "has_experience": sections["experience"],
        "has_skills": sections["skills"]
    }

    return score, missing_sections, found_skills, stats

def get_ai_suggestions(text, missing_sections, score, api_key):
    """OpenAI API kullanarak iyileştirme önerileri alır."""
    if not api_key:
        return "⚠️ Lütfen geçerli bir OpenAI API anahtarı girin."

    missing_text = ", ".join(missing_sections) if missing_sections else "Hiçbir bölüm eksik değil, tebrikler!"
    prompt = f"""Sen bir kariyer koçu ve ATS uzmanısın. Aşağıda verilen CV metnini analiz et.

ATS Skoru: {score}/100
Eksik Bölümler: {missing_text}

CV Metni:
{text[:6000]}  # Token sınırı için ilk 6000 karakter

Lütfen şu 5 başlık altında Türkçe öneriler sun:
1.  Eksik Bölümler İçin Öneriler
2.  Beceri Geliştirme Tavsiyeleri
3.  İfade ve Dil Kullanımı (Daha güçlü fiiller, başarı odaklı cümleler)
4.  Format ve Düzen (ATS dostu yapı)
5.  Genel Stratejik Tavsiyeler

Her başlık altında 2-3 somut, uygulanabilir madde olsun. Cümleler net ve profesyonel olsun.
"""
    try:
        client = OpenAI(api_key=api_key)
        response = client.chat.completions.create(
            model="gpt-3.5-turbo",
            messages=[
                {"role": "system", "content": "Sen deneyimli bir kariyer danışmanısın."},
                {"role": "user", "content": prompt}
            ],
            temperature=0.7,
            max_tokens=800
        )
        return response.choices[0].message.content
    except Exception as e:
        return f" API hatası: {e}"

def generate_ats_cv(text, title="CV"):
    """Verilen metni kullanarak ATS uyumlu Word belgesi oluşturur."""
    doc = Document()
    # Başlık
    title_para = doc.add_heading(title, level=1)
    title_para.alignment = WD_ALIGN_PARAGRAPH.CENTER

    # Metni temizle ve satırlara böl
    lines = text.split('\n')
    for line in lines:
        line = line.strip()
        if not line:
            doc.add_paragraph()  # Boş satır
        elif re.match(r'^[A-ZÇĞİÖŞÜ\s]{2,}$', line) and len(line) < 60:  # Büyük harfli başlık gibi
            doc.add_heading(line, level=2)
        elif re.match(r'^[\d]{1,2}\.?[\s]?.*', line):  # Numara ile başlayan liste
            doc.add_paragraph(line, style='List Bullet')
        else:
            p = doc.add_paragraph(line)
            p.paragraph_format.space_after = Pt(6)

    # ATS uyumlu font ayarları (tüm belge için)
    style = doc.styles['Normal']
    style.font.name = 'Times New Roman'
    style.font.size = Pt(12)

    # Bellekteki dosyayı oluştur
    file_stream = io.BytesIO()
    doc.save(file_stream)
    file_stream.seek(0)
    return file_stream

def get_download_link(file_stream, filename):
    """Word dosyası için indirme bağlantısı oluşturur."""
    b64 = base64.b64encode(file_stream.read()).decode()
    href = f'<a href="data:application/vnd.openxmlformats-officedocument.wordprocessingml.document;base64,{b64}" download="{filename}">📥 {filename}</a>'
    return href

